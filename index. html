<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Presentation</title>
  <style>
    /* Global styles */
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #F5F0E8;
    }
    
    /* Typography */
    h1 {
      font-size: 36px;
      font-weight: bold;
      color: #333;
      line-height: 42px;
    }
    p {
      font-size: 16px;
      margin-bottom: 14px;
      color: #666;
    }
    
    /* Terracotta accents */
    .terracotta {
      background-color: #E07A5F;
      padding: 10px;
      border-radius: 4px;
      box-shadow: rgba(0, 0, 0, 0.2) 0 1px 3px;
    }
    
    /* Magazine-style layout */
    .magazine {
      display: flex;
      justify-content: center;
      align-items: center;
      height: calc(100vh - 14px);
    }
    
    /* Full-screen slides */
    [data-slide] {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    [data-slide][data-active] {
      z-index: 1;
    }
    
    /* Transitions */
    [data-slide].animate {
      transition-property: transform, opacity;
      transition-duration: 500ms;
      transition-timing-function: ease-out;
    }
  </style>
</head>
<body>
  <nav id="slide-nav">
    ⬅️
    <button id="previous-button" disabled>Previous</button>
    <button id="next-button">Next</button>
    ➡️
  </nav>
  
  <!-- Slide 1 -->
  <section data-slide data-active>
    <h1>Welcome to the Presentation!</h1>
    <p>This is the first slide.</p>
  </section>
  
  <!-- Slide 2 -->
  <section data-slide>
    <h1>Why This Matters</h1>
    <p>This is the second slide, with more content.</p>
  </section>
  
  <!-- ... (omitting slides for brevity) ... -->
  
  <!-- Slide 7 -->
  <section data-slide>
    <h1>New Developments</h1>
    <p>This is the seventh slide, with exciting news!</p>
  </section>
  
  <!-- Slide 8 -->
  <section data-slide data-active>
    <h1>Conclusion</h1>
    <p>This is the final slide. Thank you for watching!</p>
  </section>
  
  <script>
    // Horizontal navigation (arrow keys and click)
    document.addEventListener("keydown", function(event) {
      if (event.key === "ArrowLeft") {
        previousSlide();
      } else if (event.key === "ArrowRight") {
        nextSlide();
      }
    });
    
    document.getElementById("previous-button").addEventListener("click", previousSlide);
    document.getElementById("next-button").addEventListener("click", nextSlide);
    
    function previousSlide() {
      const activeSlide = document.querySelector("[data-active]");
      if (activeSlide.previousElementSibling) {
        activeSlide.preventDefault();
        activeSlide.previousElementSibling.querySelector("[data-slide]").dataset.active = true;
        activeSlide.dataset.active = false;
      }
    }
    
    function nextSlide() {
      const activeSlide = document.querySelector("[data-active]");
      if (activeSlide.nextElementSibling) {
        activeSlide.preventDefault();
        activeSlide.nextElementSibling.querySelector("[data-slide]").dataset.active = true;
        activeSlide.dataset.active = false;
      }
    }
  </script>
</body>
</html>